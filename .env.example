# QQ 邮箱 IMAP 凭据（仅在需要自动下载账单时填写）
# 获取授权码：QQ 邮箱 → 设置 → 账户 → POP3/IMAP 服务 → 生成授权码
BOC_EMAIL=你的邮箱
BOC_AUTH_CODE=你的邮箱授权码

# IMAP 服务器（QQ 邮箱固定为 imap.qq.com，163 邮箱为 imap.163.com）
BOC_IMAP_SERVER=imap.qq.com

# 账单下载目录（可选，默认 data/input/）
# BOC_DOWNLOAD_DIR=

# 大额支出阈值（元，跨账期步骤中超过此值的支出会被标黄供人工核查）
# HIGHLIGHT_THRESHOLD=200
